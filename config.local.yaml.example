# Local operator overrides for adversarial-review.
# Copy relevant keys into config.local.yaml; this example is not loaded.

reviewer:
  gemini:
    # Default is cli. Antigravity mode requires at least one account entry.
    runtime: antigravity
    antigravity:
      accounts:
        - id: primary
          tokenFile: op://Cliovault/GEMINI_ANTIGRAVITY_PRIMARY/token
        - id: backup
          tokenFile: /Users/airlock/.config/gemini/backup-oauth.json
