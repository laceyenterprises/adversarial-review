# GitHub — read access for PR polling
GITHUB_TOKEN=ghp_...

# GitHub bot PATs — write access to post reviews
# Used by codex-reviewer-lacey bot (reviews Claude/Clio PRs)
GH_CODEX_REVIEWER_TOKEN=ghp_...

# Used by claude-reviewer-lacey bot (reviews Codex PRs)
GH_CLAUDE_REVIEWER_TOKEN=ghp_...

# Optional routing pins.
# Leave unset for normal opposite-agent review routing.
# Set to codex to lock Claude out of first-pass reviews.
# ADVERSARIAL_REVIEW_DEFAULT_REVIEWER=codex

# Leave unset for the current codex remediation default.
# Set to claude-code only when Claude Code is approved for unattended remediation.
# ADVERSARIAL_REVIEW_DEFAULT_REMEDIATOR=codex

# AI provider keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Linear — for ticket status updates
LINEAR_API_KEY=lin_api_...
