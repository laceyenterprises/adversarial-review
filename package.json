{
  "name": "adversarial-review",
  "version": "1.0.0",
  "description": "Adversarial cross-model code review service for agent-built PRs",
  "type": "module",
  "main": "src/watcher.mjs",
  "bin": {
    "adversarial-review": "src/cli.mjs"
  },
  "scripts": {
    "start": "node src/watcher.mjs",
    "review": "node src/reviewer.mjs",
    "pr:create:tagged": "node src/pr-create-tagged.mjs",
    "test": "node --test test/*.test.mjs",
    "follow-up:consume": "node src/follow-up-remediation.mjs",
    "follow-up:reconcile": "node src/follow-up-reconcile.mjs",
    "follow-up:requeue": "node src/follow-up-requeue.mjs",
    "follow-up:stop": "node src/follow-up-stop.mjs",
    "check-branch-protection": "node src/check-branch-protection.mjs",
    "retrigger-review": "node src/retrigger-review.mjs",
    "retrigger-remediation": "node src/retrigger-remediation.mjs",
    "reset-pr": "node src/reset-pr.mjs",
    "typecheck:contracts": "tsc --noEmit --module NodeNext --moduleResolution NodeNext --target ES2022 --strict test/fixtures/kernel/contracts-check.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@linear/sdk": "^27.0.0",
    "@octokit/rest": "^21.1.1",
    "better-sqlite3": "^11.9.1",
    "openai": "^4.98.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
