<?xml version="1.0" encoding="UTF-8"?>
<!--
  Per-user LaunchAgent for the adversarial-review follow-up daemon.

  Filename convention: `.<user>.plist` binds this plist to a specific
  operator's home directory (matching the watcher's `.placey.plist`).
  The os-restart auto-install path copies this file verbatim to
  `~<user>/Library/LaunchAgents/ai.laceyenterprises.adversarial-follow-up.plist`
  (deployed name drops the `.placey` suffix). To run the daemon as a
  different operator OR on a host where the repo lives at a different
  absolute path, copy this plist as `.<that-user>.plist` and substitute
  BOTH literals:
    - every `/Users/placey` reference → that operator's home
    - every `/Users/airlock/agent-os` reference → the absolute Agent OS
      repo root on that host
  Then add the matching entry to `os-restart.sh`'s
  INSTALLABLE_USER_AGENT_PLISTS / USER_AGENTS arrays. See README
  "Install for a different user or host" for the canonical sed recipe.

  Why hardcoded paths: `EnvironmentVariables` in launchd plists do not
  support shell expansion, so `$HOME` and `$AGENT_OS_ROOT` cannot be
  referenced from within this file. The tick script
  (scripts/adversarial-follow-up-tick.sh) derives CODEX_AUTH_PATH and
  any user-relative path from `$HOME` at runtime, and honors an
  AGENT_OS_ROOT env override for the repo root, but launchd itself
  needs literal paths to find the script and chdir into the repo
  before exec — so HOME, log paths, and both literal repo-root
  references must be edited per host.

  Long-lived process model (changed 2026-05-02): the daemon used to be
  a one-shot tick (StartInterval=120, exit each cycle). That triggered
  a 1Password / TCC popup storm because launchd-spawned `op` and `gh`
  subprocesses aren't process-trusted by the macOS 1Password app and
  by macOS's privacy gatekeeper the same way an interactive shell's
  are — each fresh subprocess re-prompted, so 2 op calls + 1 gh call
  per tick × 1 tick per 2min = a popup every minute. Converted to a
  long-lived `while true; sleep 120` loop in the tick script: secrets
  resolve ONCE at daemon start (one popup per system boot), then ticks
  reuse them in-process. KeepAlive=SuccessfulExit=false relaunches on
  crash but not on clean exit so we don't dance around the popups.

  Not generic / not portable across machines: WorkingDirectory and the
  ProgramArguments path embed `/Users/airlock/agent-os/`. That is the
  documented Agent OS root on this host (matching the existing
  watcher plist). For a different host, sed-substitute these literals
  before installing (see README); setting AGENT_OS_ROOT in
  EnvironmentVariables only relocates the in-script repo lookup, not
  the launchd-level ProgramArguments path that points at this script.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>ai.laceyenterprises.adversarial-follow-up</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>/Users/airlock/agent-os/tools/adversarial-review/scripts/adversarial-follow-up-tick.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/airlock/agent-os/tools/adversarial-review</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <!-- HOME is the only per-user value this plist hardcodes; the tick
             script derives every other user-relative path from it. -->
        <key>HOME</key>
        <string>/Users/placey</string>
    </dict>

    <!-- Long-lived: the script runs an internal `while true; sleep 120`
         loop and never exits cleanly. KeepAlive with SuccessfulExit=false
         means launchd respawns on crash but not on clean exit; the
         script never exits cleanly anyway, so this is purely a safety
         net for unexpected crashes. -->
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <!-- Throttle relaunches so a crash spiral doesn't burn through
         1Password/TCC popups on every restart attempt. -->
    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/placey/Library/Logs/adversarial-follow-up.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/placey/Library/Logs/adversarial-follow-up.log</string>
</dict>
</plist>
