<?xml version="1.0" encoding="UTF-8"?>
<!--
  Per-user LaunchAgent for the adversarial-review watcher running as airlock.

  Filename convention: `.airlock.plist` is the airlock-side variant of
  `.placey.plist`. The os-restart auto-install path (see scripts/os-restart.sh
  INSTALLABLE_USER_AGENT_PLISTS) copies this file to
  `/Users/airlock/Library/LaunchAgents/ai.laceyenterprises.adversarial-watcher.airlock.plist`
  and bootstraps it into airlock's gui domain.

  Why airlock instead of placey: the watcher invokes `hq dispatch` for
  merge-agent jobs, which must run as the HQ ownerUser (`airlock` on
  this host). When the watcher ran as placey, every merge-agent
  dispatch hit `[hq] error: OWNER_MISMATCH running as 'placey' but
  HQ ownerUser is 'airlock'`, swallowed as `Command failed: ...` by
  the watcher's then-opaque execFile error handling. Migrating the
  watcher to airlock makes the dispatch a same-user call. See the
  PR #324 / #329 chain for the full diagnosis.

  Prereqs that must be in place on airlock BEFORE this plist boots:
    - `claude` CLI logged in (`sudo -u airlock claude login` produces
       a usable `claude auth status`)
    - `gh` CLI logged in to an account with repo access
    - the 1Password service account env at
      `/Users/airlock/agent-os/agents/clio/credentials/local/op-service-account.env`
      is readable by airlock (it already is for the dispatch-daemon)

  Label suffix: `.airlock` distinguishes from any concurrent
  `.placey.plist`. Cross-user labels must not collide; even after the
  placey LaunchAgent is bootout'd, leaving a distinct label gives
  per-user audit logs and parallel troubleshooting.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>ai.laceyenterprises.adversarial-watcher.airlock</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>/Users/airlock/agent-os/tools/adversarial-review/scripts/adversarial-watcher-start.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/airlock/agent-os/tools/adversarial-review</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <string>/Users/airlock</string>
        <key>USER</key>
        <string>airlock</string>
        <key>LOGNAME</key>
        <string>airlock</string>
        <key>SHELL</key>
        <string>/bin/zsh</string>
        <key>HQ_ROOT</key>
        <string>/Users/airlock/agent-os-hq</string>

        <!--
          ALERT_TO 1Password ref is REQUIRED for the watcher to start.
          The watcher's startup script (`scripts/adversarial-watcher-start.sh`)
          resolves this op:// ref via the service-account token and fail-loud
          refuses to start without it. Hardcoded here as the operator's
          standing default. Operators who want to suppress paging (e.g. dev
          envs) set `ADVERSARIAL_REVIEW_ALLOW_MISSING_ALERT_TO=1` on the
          plist + drop this line. See `scripts/adversarial-watcher-start.sh`
          for the resolution contract.
        -->
        <key>ADVERSARIAL_REVIEW_ALERT_TO_OP_REF</key>
        <string>op://Cliovault/adversarial-watcher-alert-to/credential</string>

        <!--
          BUILD-PACK-DEFAULT-FLIP / 2026-05-29 → 2026-05-30 → reverted
          2026-05-30 (PT) when codex OAuth came back online. Per the
          operator directive: remediator pins to `codex`; reviewer
          pins to `adversarial` (cross-model adversarial-by-default —
          the value also lives in config.yaml, so this env entry is
          really just a belt-and-suspenders explicit override).

          See LAC-893 + the role-pin env knobs documented in
          `docs/follow-up-runbook.md`.
        -->
        <key>ADVERSARIAL_REVIEW_DEFAULT_REVIEWER</key>
        <string>adversarial</string>
        <key>ADVERSARIAL_REVIEW_DEFAULT_REMEDIATOR</key>
        <string>codex</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/airlock/Library/Logs/adversarial-watcher.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/airlock/Library/Logs/adversarial-watcher.log</string>

    <key>ThrottleInterval</key>
    <integer>30</integer>
</dict>
</plist>
