# GitHub — read access for PR polling
GITHUB_TOKEN=ghp_...

# GitHub bot PATs — write access to post reviews
# Used by codex-reviewer-lacey bot (reviews Claude/Clio PRs)
GH_CODEX_REVIEWER_TOKEN=ghp_...

# Used by claude-reviewer-lacey bot (reviews Codex PRs)
GH_CLAUDE_REVIEWER_TOKEN=ghp_...

# Optional routing pins.
# Leave unset for normal opposite-agent review routing.
# Set to codex to lock Claude out of first-pass reviews.
# ADVERSARIAL_REVIEW_DEFAULT_REVIEWER=codex

# Leave unset for the current codex remediation default.
# Set to claude-code only when Claude Code is approved for unattended remediation.
# ADVERSARIAL_REVIEW_DEFAULT_REMEDIATOR=codex

# AI provider keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Linear — for ticket status updates
LINEAR_API_KEY=lin_api_...

# Offline-period / quota-outage stale-state reaper thresholds (watcher startup).
# After a host outage (macOS upgrade + os-restart, a GitHub rate-limit storm, or
# any long watcher-down window) the reaper releases abandoned in-flight state so
# PRs re-review and AMA closers re-dispatch instead of wedging until manual
# rescue. Both default to 6h; lower only if you understand the live-work race.
# Age (ms) past which a `status='running'` reviewer pass is treated as a zombie.
# ADVERSARIAL_STALE_RUNNING_REVIEWER_PASS_MS=21600000
# Age (ms) past which a non-terminal AMA closer lease is released.
# ADVERSARIAL_STALE_CLOSER_LEASE_MS=21600000
