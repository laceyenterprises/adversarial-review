<?xml version="1.0" encoding="UTF-8"?>
<!--
  Per-user LaunchAgent for the adversarial-review watcher running as airlock.

  Filename convention: `.airlock.plist` is the airlock-side variant of
  `.placey.plist`. The os-restart auto-install path (see scripts/os-restart.sh
  INSTALLABLE_USER_AGENT_PLISTS) copies this file to
  `/Users/airlock/Library/LaunchAgents/ai.laceyenterprises.adversarial-watcher.airlock.plist`
  and bootstraps it into airlock's gui domain.

  Why airlock instead of placey: the watcher invokes `hq dispatch` for
  merge-agent jobs, which must run as the HQ ownerUser (`airlock` on
  this host). When the watcher ran as placey, every merge-agent
  dispatch hit `[hq] error: OWNER_MISMATCH running as 'placey' but
  HQ ownerUser is 'airlock'`, swallowed as `Command failed: ...` by
  the watcher's then-opaque execFile error handling. Migrating the
  watcher to airlock makes the dispatch a same-user call. See the
  PR #324 / #329 chain for the full diagnosis.

  Prereqs that must be in place on airlock BEFORE this plist boots:
    - `claude` CLI logged in (`sudo -u airlock claude login` produces
       a usable `claude auth status`)
    - `gh` CLI logged in to an account with repo access
    - the 1Password service account env at
      `/Users/airlock/agent-os/agents/clio/credentials/local/op-service-account.env`
      is readable by airlock (it already is for the dispatch-daemon)

  Label suffix: `.airlock` distinguishes from any concurrent
  `.placey.plist`. Cross-user labels must not collide; even after the
  placey LaunchAgent is bootout'd, leaving a distinct label gives
  per-user audit logs and parallel troubleshooting.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>ai.laceyenterprises.adversarial-watcher.airlock</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>/Users/airlock/agent-os/tools/adversarial-review/scripts/adversarial-watcher-start.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/airlock/agent-os/tools/adversarial-review</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>AGENT_OS_SESSION_LEDGER_DSN</key>
        <string>postgresql://airlock@127.0.0.1:6432/agent_os_ledger</string>
        <key>AGENT_OS_SESSION_LEDGER_TARGET</key>
        <string>postgresql://airlock@127.0.0.1:6432/agent_os_ledger</string>
        <key>ADVERSARIAL_REVIEW_WATCHER_PLIST_PATH</key>
        <string>/Users/airlock/agent-os/tools/adversarial-review/launchd/ai.laceyenterprises.adversarial-watcher.airlock.plist</string>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <string>/Users/airlock</string>
        <key>USER</key>
        <string>airlock</string>
        <key>LOGNAME</key>
        <string>airlock</string>
        <key>SHELL</key>
        <string>/bin/zsh</string>
        <key>HQ_ROOT</key>
        <string>/Users/airlock/agent-os-hq</string>

        <!--
          ALERT_TO 1Password ref is REQUIRED for the watcher to start.
          The watcher's startup script (`scripts/adversarial-watcher-start.sh`)
          resolves this op:// ref via the service-account token and fail-loud
          refuses to start without it. Hardcoded here as the operator's
          standing default. Operators who want to suppress paging (e.g. dev
          envs) set `ADVERSARIAL_REVIEW_ALLOW_MISSING_ALERT_TO=1` on the
          plist + drop this line. See `scripts/adversarial-watcher-start.sh`
          for the resolution contract.
        -->
        <key>ADVERSARIAL_REVIEW_ALERT_TO_OP_REF</key>
        <string>op://Cliovault/adversarial-watcher-alert-to/credential</string>

        <!--
          BUILD-PACK-DEFAULT-FLIP / 2026-05-29 → 2026-05-30 → reverted
          2026-05-30 (PT) when codex OAuth came back online. Per the
          operator directive: remediator pins to `codex` as an explicit
          launchd override. The module config.yaml keeps its default for
          non-launchd/dev runs.

          2026-06-18: reviewer env pin REMOVED (operator: "now that Claude
          is back online, flip the default reviewer back to adversarial").
          The reviewer role now resolves from config — roles.reviewer:
          adversarial in config.local.yaml — restoring the cross-model
          claude<->codex builder-never-reviews routing. This env pin (Layer 5)
          was overriding the yaml (Layer 4), so it had to be removed for the
          flip to take effect.

          2026-07-21: remediator env pin REMOVED too (operator: "codex quota
          is back on — this should be config not in the plist"). The remediator
          role now resolves from config — roles.remediator: codex in
          config.local.yaml (Layer 4) — so no launchd env pin (Layer 5)
          overrides it. This reverts #672, which had pinned the remediator to
          claude-code in this template during the codex quota outage.

          See LAC-893 + the role-pin env knobs documented in
          `docs/follow-up-runbook.md`.
        -->
        <!--
          Resolve reviewer GitHub credentials through the local OAuth
          broker instead of per-role 1Password PAT reads. The expected
          IDs pin the broker response to the reviewer GitHub Apps
          documented in the model-routing runtime compose file.
        -->
        <key>CLAUDE_REVIEWER_AUTH_VIA_BROKER</key>
        <string>true</string>
        <key>CODEX_REVIEWER_AUTH_VIA_BROKER</key>
        <string>true</string>
        <key>GEMINI_REVIEWER_AUTH_VIA_BROKER</key>
        <string>true</string>
        <!--
          Antigravity `agy` auth preflight is ~15x slower under launchd than in
          a login shell: the per-user keyring token read takes ~12s in a
          daemon with no interactive session (vs a fast fail-to-file-token in a
          shell), so a full `agy models` probe runs ~30s. The module default
          (DEFAULT_AGY_AUTH_PROBE_TIMEOUT_MS = 5000 in src/agy-reviewer-auth.mjs)
          is fine for shells but far too short here, and a probe timeout is
          mis-reported as `agy-probe-timeout` → "OAuth credentials unavailable"
          → the reviewer STOPS. Pin a launchd-appropriate budget so the healthy-
          but-slow keyring path completes. The 60s success cache means this is
          paid at most once per minute, not per review. 2026-07-10; verified by
          reviews reposting on #3377/#3380 after raising this at runtime.
        -->
        <key>AGY_AUTH_PROBE_TIMEOUT_MS</key>
        <string>45000</string>
        <key>OAUTH_BROKER_SHARED_SECRET_FILE</key>
        <string>/Users/airlock/agent-os/.secrets/local/oauth-broker-shared-secret</string>
        <key>OAUTH_BROKER_CLAUDE_REVIEWER_EXPECTED_APP_ID</key>
        <string>3994110</string>
        <key>OAUTH_BROKER_CLAUDE_REVIEWER_EXPECTED_INSTALLATION_ID</key>
        <string>138772505</string>
        <key>OAUTH_BROKER_CODEX_REVIEWER_EXPECTED_APP_ID</key>
        <string>3994060</string>
        <key>OAUTH_BROKER_CODEX_REVIEWER_EXPECTED_INSTALLATION_ID</key>
        <string>138771486</string>
        <key>OAUTH_BROKER_GEMINI_REVIEWER_EXPECTED_APP_ID</key>
        <string>3994139</string>
        <key>OAUTH_BROKER_GEMINI_REVIEWER_EXPECTED_INSTALLATION_ID</key>
        <string>138773049</string>
        <!--
          Operator kill-switch for the adversarial-gate GitHub status
          check (2026-06-07). When set to `true`, the watcher skips
          the `gh api POST repos/.../statuses/<headSha>` call in
          `publishAdversarialGateStatus`. Reviews + remediation
          continue to run; only the GitHub-side gating status check
          is suppressed. To re-enable, change to `false` (or remove)
          + `launchctl kickstart -k gui/502/ai.laceyenterprises.adversarial-watcher.airlock`.

          Why this kill-switch exists: free-tier private repos cannot
          enforce required status checks, but the watcher's posted
          status was still appearing as a PENDING/SUCCESS context in
          PR UIs and tripping operator workflow.
        -->
        <key>ADVERSARIAL_GATE_STATUS_DISABLED</key>
        <string>true</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/airlock/Library/Logs/adversarial-watcher.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/airlock/Library/Logs/adversarial-watcher.log</string>

    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>ExitTimeOut</key>
    <integer>45</integer>
</dict>
</plist>
