#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

staged_files=()
while IFS= read -r -d '' path; do
  if [[ "$path" =~ ^src/.*\.(mjs|js)$ ]]; then
    staged_files+=("$path")
  fi
done < <(git diff --cached --name-only -z --diff-filter=ACM)

if [[ ${#staged_files[@]} -eq 0 ]]; then
  exit 0
fi

stash_ref_before="$(git rev-parse -q --verify refs/stash || true)"
stash_name="pre-commit-eslint-keep-index"
restore_stash=0

restore_worktree() {
  if [[ "$restore_stash" -eq 1 ]]; then
    git stash pop -q --index >/dev/null
  fi
}

trap restore_worktree EXIT

git stash push --keep-index --include-untracked -q -m "$stash_name" >/dev/null || true
stash_ref_after="$(git rev-parse -q --verify refs/stash || true)"
if [[ "$stash_ref_after" != "$stash_ref_before" ]]; then
  restore_stash=1
fi

npx eslint "${staged_files[@]}"
