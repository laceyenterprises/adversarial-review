{
  "id": "code-pr",
  "enabled": true,
  "subjectChannel": "github-pr",
  "commsChannel": "github-pr-comments",
  "reviewerRuntime": "cli-direct",
  "operatorSurface": {
    "controls": "github-pr-label-controls",
    "triageSync": "linear"
  },
  "promptSet": "code-pr",
  "riskClasses": {
    "low": {
      "maxRemediationRounds": 1
    },
    "medium": {
      "maxRemediationRounds": 2
    },
    "high": {
      "maxRemediationRounds": 3
    },
    "critical": {
      "maxRemediationRounds": 4
    }
  },
  "reviewerRouting": {
    "codex": "claude-reviewer-lacey",
    "claude-code": "codex-reviewer-lacey",
    "clio-agent": "codex-reviewer-lacey"
  },
  "pipeline": {
    "enabled": false,
    "stages": [
      {
        "id": "code-quality",
        "panel": ["code-quality-reviewer"],
        "aggregation": { "kind": "unanimous-clean" }
      },
      {
        "id": "security",
        "panel": ["security-reviewer"],
        "aggregation": { "kind": "unanimous-clean" }
      }
    ]
  }
}
